#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

struct Job {
    int start, finish, profit;
};

// Comparator to sort jobs by finish time
bool compare(Job a, Job b) {
    return a.finish < b.finish;
}

// Find latest non-conflicting job
int latestNonConflict(vector<Job>& jobs, int i) {
    for (int j = i - 1; j >= 0; j--) {
        if (jobs[j].finish <= jobs[i].start)
            return j;
    }
    return -1;
}

// Function to find maximum profit
int weightedJobScheduling(vector<Job>& jobs, int n) {
    sort(jobs.begin(), jobs.end(), compare);

    vector<int> dp(n);
    dp[0] = jobs[0].profit;

    for (int i = 1; i < n; i++) {
        int includeProfit = jobs[i].profit;
        int l = latestNonConflict(jobs, i);

        if (l != -1)
            includeProfit += dp[l];

        dp[i] = max(includeProfit, dp[i - 1]);
    }

    return dp[n - 1];
}

int main() {
    int n;
    cout << "Enter number of jobs: ";
    cin >> n;

    vector<Job> jobs(n);

    cout << "Enter start time, finish time, and profit:\n";
    for (int i = 0; i < n; i++) {
        cin >> jobs[i].start >> jobs[i].finish >> jobs[i].profit;
    }

    cout << "Maximum Profit: " << weightedJobScheduling(jobs, n);

    return 0;
}
